default_platform(:android)

platform :android do
  desc "Distribute app to Firebase Distribution"
  lane :build_test do |options|
    release_notes = options[:release_notes] || ENV["RELEASE_NOTES"] || "New release"
    
    # Build release APK
    gradle(
      task: "assembleRelease",
      project_dir: "."
    )

    # Upload to Firebase Distribution
    firebase_app_distribution(
      app: "1:1030168532004:android:5524dc19fd99cb5b5bb4b1",
      apk_path: "app/release/app-release.apk",
      groups: "testers",
      release_notes: release_notes
    )
  end
end